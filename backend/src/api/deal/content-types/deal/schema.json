{
  "kind": "collectionType",
  "collectionName": "deals",
  "info": {
    "singularName": "deal",
    "pluralName": "deals",
    "displayName": "Deal",
    "description": "Sales Deals"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "value": {
      "type": "decimal",
      "required": true
    },
    "stage": {
      "type": "enumeration",
      "enum": [
        "survey",
        "quote",
        "negotiation",
        "waiting_payment",
        "closed",
        "lost"
