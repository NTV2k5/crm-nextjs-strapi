Admin --> UC26
Manager --> UC26
Admin --> UC27
Manager --> UC27
Admin --> UC28
Manager --> UC28

Admin --> UC30
Manager --> UC30
Admin --> UC31
Manager --> UC31
Admin --> UC32
Manager --> UC32
Admin --> UC33
Manager --> UC33
Admin --> UC34
Manager --> UC34
Admin --> UC35
Manager --> UC35

Admin --> UC40
Manager --> UC40
Admin --> UC41
Manager --> UC41
Admin --> UC43
Manager --> UC43
Admin --> UC44
Manager --> UC44
Admin --> UC45
Manager --> UC45

Admin --> UC50
Manager --> UC50
Admin --> UC51
Manager --> UC51
Admin --> UC52
Manager --> UC52

Admin --> UC60
Manager --> UC60
Admin --> UC61
Manager --> UC61
Admin --> UC62
Manager --> UC62

' -- Sales (limited scope - assigned only) --
Sales --> UC10
Sales --> UC11
Sales --> UC12
Sales --> UC13
Sales --> UC15
Sales --> UC17
Sales --> UC20
Sales --> UC21
Sales --> UC25
Sales --> UC26
