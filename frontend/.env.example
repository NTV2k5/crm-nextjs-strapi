VITE_FIREBASE_API_KEY="your-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-auth-domain"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-storage-bucket"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-messaging-sender-id"
VITE_FIREBASE_APP_ID="your-app-id"

# SePay – Vietnam bank-transfer / VietQR payments
# Docs: https://docs.sepay.vn
VITE_SEPAY_BANK_ACCOUNT="your-bank-account-number"   # Số tài khoản thụ hưởng
VITE_SEPAY_BANK_NAME="Vietcombank"                    # Tên ngân hàng viết tắt (https://qr.sepay.vn/banks.json)
# ⚠️  Move VITE_SEPAY_API_TOKEN to a secure backend in production!
VITE_SEPAY_API_TOKEN="your-sepay-api-token"           # Lấy tại my.sepay.vn > API Token

# Resend – Transactional Emails
# Docs: https://resend.com/docs
VITE_RESEND_API_KEY="your-resend-api-key"
VITE_EMAIL_FROM="CRM Team <onboarding@resend.dev>"
